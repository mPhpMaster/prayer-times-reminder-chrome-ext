{
    "manifest_version": 3,
    "name": "Prayer Times Reminder",
    "short_name": "Prayer Times Break",
    "version": "2.1.1",
    "description": "Prayer Times Break: locks your tabs at prayer time so you can pray — plus reminders, daily schedule, dhikr, themes, and 8 languages.",
    "permissions": ["alarms", "notifications", "storage", "geolocation", "tabs", "scripting"],
    "host_permissions": [
        "https://api.aladhan.com/*",
        "https://countriesnow.space/*",
        "https://nominatim.openstreetmap.org/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Prayer Times Reminder",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}